{
  "name": "react-native-turbo-sqlite",
  "version": "0.5.0",
  "description": "Pure C++ TurboModule for sqlite3",
  "source": "./src/index.ts",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "react-native": "./lib/module/index",
  "browser": "./lib/module/index.browser.js",
  "exports": {
    ".": {
      "browser": {
        "import": {
          "types": "./lib/typescript/module/src/index.browser.d.ts",
          "default": "./lib/module/index.browser.js"
        },
        "require": {
          "types": "./lib/typescript/commonjs/src/index.browser.d.ts",
          "default": "./lib/commonjs/index.browser.js"
        },
        "default": "./lib/module/index.browser.js"
      },
      "react-native": "./lib/module/index.js",
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": {
      "require": "./package.json",
      "import": "./package.json"
    },
    "./mocks": {
      "import": {
        "types": "./lib/typescript/module/src/mocks.d.ts",
        "default": "./lib/module/mocks.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/mocks.d.ts",
        "default": "./lib/commonjs/mocks.js"
      }
    },
    "./browser": {
      "browser": {
        "default": "./lib/module/index.browser.js"
      },
      "import": {
        "types": "./lib/typescript/module/src/index.browser.d.ts",
        "default": "./lib/module/index.browser.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.browser.d.ts",
        "default": "./lib/commonjs/index.browser.js"
      }
    }
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "react-native.config.js",
    "windows"
  ],
  "scripts": {
    "example": "yarn workspace react-native-turbo-sqlite-example",
    "example:web": "yarn workspace react-native-turbo-sqlite-example web",
    "test": "jest",
    "typecheck": "tsc",
    "lint": "eslint babel.config.js react-native.config.js src tests scripts example/src example/vite.config.ts",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "vendor:sqlite-wasm": "node scripts/vendor-sqlite-wasm.cjs",
    "codegen": "node scripts/generate-codegen-specs.cjs",
    "codegen:standard": "node scripts/generate-codegen-specs.cjs --standard-only",
    "codegen:windows": "node scripts/generate-codegen-specs.cjs --windows-jsi-only",
    "prepare": "yarn codegen && bob build",
    "prepack": "yarn prepare",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+http://github.com/hsjoberg/react-native-turbo-sqlite.git"
  },
  "author": "Hampus Sjöberg <hampus.sjoberg@protonmail.com> (http://blixtwallet.com)",
  "license": "MIT",
  "bugs": {
    "url": "http://github.com/hsjoberg/react-native-turbo-sqlite/issues"
  },
  "homepage": "http://github.com/hsjoberg/react-native-turbo-sqlite#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.0.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-windows/codegen": "0.82.0",
    "@react-native/eslint-config": "0.82.1",
    "@release-it/conventional-changelog": "^10.0.5",
    "@sqlite.org/sqlite-wasm": "3.51.2-build8",
    "@types/jest": "^29.5.5",
    "@types/react": "^19.1.1",
    "@types/sql.js": "^1.4.9",
    "commitlint": "^19.0.0",
    "conventional-changelog-angular": "^8.3.0",
    "del-cli": "^5.1.0",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "react": "19.1.1",
    "react-native": "0.82.1",
    "react-native-builder-bob": "^0.40.18",
    "react-native-windows": "0.82.0",
    "release-it": "^19.2.4",
    "sql.js": "^1.14.1",
    "turbo": "^1.10.7",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@types/react": "^19.1.1"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@3.6.1",
  "engines": {
    "node": ">=20"
  },
  "jest": {
    "preset": "react-native",
    "testPathIgnorePatterns": [
      "<rootDir>/example/e2e/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "requireBranch": "master",
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "plugins": [
      "prettier"
    ],
    "extends": [
      "@react-native",
      "prettier"
    ],
    "rules": {
      "eslint-comments/no-unlimited-disable": "off",
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": false,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ],
      "react-native/no-inline-styles": "off"
    },
    "overrides": [
      {
        "files": [
          "example/e2e/**/*.js",
          "example/.detoxrc.js"
        ],
        "env": {
          "jest": true
        },
        "globals": {
          "device": "readonly",
          "element": "readonly",
          "by": "readonly",
          "waitFor": "readonly",
          "expect": "readonly"
        }
      }
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/",
    "src/vendor/",
    "!example/.detoxrc.js"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNTurboSqliteSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "outputDir": {
      "android": "android/build"
    },
    "android": {
      "javaPackageName": "com.turbosqlite"
    }
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "module-new",
    "version": "0.41.2"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "ReactNativeTurboSqlite",
      "namespace": "ReactNativeTurboSqlite",
      "template": "cpp-lib"
    }
  }
}
